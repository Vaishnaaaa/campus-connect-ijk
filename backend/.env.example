# ── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/campusconnect
# Or MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/campusconnect

# ── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Firebase Admin SDK ───────────────────────────────
# Paste the values from your Firebase project → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=campusconnect-ijk
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Frontend URL (for CORS) ───────────────────────────
CLIENT_URL=http://localhost:3000
